{#
  valkey.j2 — reusable Valkey service block (Redis-compatible replacement)

  Usage:
    {% from 'macros/valkey.j2' import valkey %}
    {{ valkey('MyApp-VALKEY') }}

  Parameters:
    container_name  : Docker container name
    network         : network name (default: internal)
    version         : image tag (default: 8-alpine)
    command         : optional valkey command args
#}
{% macro valkey(container_name, network='internal', version='8-alpine', command='') %}
  {{ container_name }}:
    image: docker.io/valkey/valkey:{{ version }}
    container_name: {{ container_name }}
{% if command %}
    command: {{ command }}
{% endif %}
    networks:
      - {{ network }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endmacro %}
