{#
  redis.j2 — reusable Redis service block

  Include version in container_name and volume_name so upgrades can run
  old and new side by side. Declare the named volume in the calling template:

    volumes:
      MyApp_Redis_R{{ myapp_redis_version }}:
        name: MyApp_Redis_R{{ myapp_redis_version }}

  Usage:
    {% from 'macros/redis.j2' import redis %}
    {{ redis('MyApp-Redis_R' + myapp_redis_version,
             volume_name='MyApp_Redis_R' + myapp_redis_version) }}

  Parameters:
    container_name  : Docker container name (include version)
    volume_name     : Named volume for persistence (include version)
    network         : network name (default: internal)
    version         : image tag (default: 7-alpine)
    command         : optional redis command args (e.g. '--save 60 1')
#}
{% macro redis(container_name, volume_name='', network='internal', version='7-alpine', command='') %}
  {{ container_name }}:
    image: docker.io/library/redis:{{ version }}
    container_name: {{ container_name }}
{% if command %}
    command: {{ command }}
{% endif %}
{% if volume_name %}
    volumes:
      - {{ volume_name }}:/data
{% endif %}
    networks:
      - {{ network }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endmacro %}
