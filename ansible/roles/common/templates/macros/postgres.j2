{#
  postgres.j2 — reusable PostgreSQL service block

  Usage in a compose template:
    {% from 'macros/postgres.j2' import postgres %}
    {{ postgres('MyApp-DB', 'myapp', myapp_db_user, myapp_db_password) }}

  Parameters:
    container_name  : Docker container name
    db_name         : POSTGRES_DB value
    db_user         : POSTGRES_USER value (pass Ansible variable, resolved at template time)
    db_password     : POSTGRES_PASSWORD value (pass Ansible variable, resolved at template time)
    data_subpath    : relative path inside stack dir for data volume (default: data/db)
    network         : network name to attach to (default: internal)
    version         : PostgreSQL major version (default: 17)
    variant         : image variant — alpine, bookworm, etc. (default: alpine)
    extra_image     : override full image (e.g. pgvector/pgvector:pg16 — replaces version+variant)
#}
{% macro postgres(container_name, db_name, db_user, db_password,
                  data_subpath='data/db', network='internal',
                  version='17', variant='alpine', extra_image='') %}
  {{ container_name }}:
    image: {% if extra_image %}{{ extra_image }}{% else %}docker.io/library/postgres:{{ version }}-{{ variant }}{% endif %}

    container_name: {{ container_name }}
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
    volumes:
      - ./{{ data_subpath }}:/var/lib/postgresql/data
    networks:
      - {{ network }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endmacro %}
